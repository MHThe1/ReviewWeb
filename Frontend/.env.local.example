# =============================================================================
# Frontend — Local Development (without Docker)
# =============================================================================
# Only needed if you're running the frontend directly with npm run dev.
# When using Docker Compose, NEXT_PUBLIC_API_URL is injected by docker-compose.yml.
#
# Usage:
#   cp .env.local.example .env.local
# =============================================================================

# Backend API base URL
# For local dev: http://localhost:8000/api
# For production: https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
