# =============================================================================
# Review Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# For local Docker development, the defaults work as-is.
# For production, update all values marked with [REQUIRED].
# =============================================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=review_db
# [REQUIRED] Full PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@db:5432/review_db

# --- JWT Authentication ---
# [REQUIRED] Change this to a strong random secret in production
JWT_SECRET_KEY=super-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Backend CORS ---
# Comma-separated list of allowed origins (no spaces)
# For production, set to your deployed frontend URL
# Example: https://review-web-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
# [REQUIRED] Backend API URL for the frontend to call
# For local dev: http://localhost:8000/api
# For production: https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
