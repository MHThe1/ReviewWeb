# =============================================================================
# Backend — Local Development (without Docker)
# =============================================================================
# Only needed if you're running the backend directly with uvicorn.
# When using Docker Compose, environment variables are injected by docker-compose.yml
# and the root-level .env file is used instead.
#
# Usage:
#   cp .env.example .env
#   # then edit DATABASE_URL to match your local PostgreSQL credentials
# =============================================================================

# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
# ⚠️  If your password contains special characters (@, !, #, $, etc.),
#     URL-encode them: @ → %40, ! → %21, # → %23, $ → %24
#     Example: password "p@ss!" becomes "p%40ss%21" in the URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_db

# JWT Authentication
# Change JWT_SECRET_KEY to any long random string in production
JWT_SECRET_KEY=super-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS — allowed origins for the frontend
CORS_ORIGINS=http://localhost:3000
